    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.21.4",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite": "^6.4.3",
    "wrangler": "^4.107.1"
  }
