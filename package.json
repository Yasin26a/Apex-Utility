    "ajv": "^8.20.0",
    "crypto-js": "^4.2.0",
    "d3": "^7.9.0",
    "exifreader": "^4.41.0",
    "express": "^4.19.2",
    "fflate": "^0.8.3",
    "gifenc": "^1.0.3",
    "html2canvas": "^1.4.1",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.395.0",
    "motion": "^11.2.10",
    "muhammara": "^6.0.5",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^3.9.1",
    "sql-formatter": "^15.8.2",
    "tesseract.js": "^7.0.0"
